# Copy to .env (local) or Railway Variables (production).
# Check deployment: GET https://<your-app>/api/health

NODE_ENV=development
PORT=3000

# ─── Required (app) ───────────────────────────────────────────────────────────
JWT_SECRET=change-me-local-dev-secret
DATABASE_URL=mysql://user:pass@host:3306/fastvid

# OAuth (optional if using email/password only)
# VITE_APP_ID=
# OAUTH_SERVER_URL=

# Admin bootstrap (first admin on startup if none exists)
# ADMIN_EMAIL=you@example.com
# ADMIN_PASSWORD=choose-a-strong-password

# ─── Script (required for video generation) ───────────────────────────────────
# At least one LLM key (Forge → OpenAI → Groq):
# BUILT_IN_FORGE_API_KEY=
# LLM_API_KEY=                     # OpenAI (gpt-4o) — default on Railway
# GROQ_API_KEY=                    # Optional Groq fallback (LLM_PROVIDER=groq)
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_VISION_MODEL=llama-3.2-11b-vision-preview

# ─── Vision QA (clip ↔ narration check during video generation) ─────────────
# On by default when LLM_API_KEY is set. Rejects wrong-country/wrong-subject B-roll.
# Verify after deploy: GET https://<your-app>/api/health → visionQA.ready should be true
# Logs during generation: [VisionGate] … reject …  and  [SceneCritical] … OK/FAIL
# ENABLE_CINEMATIC_EFFECTS=true      # Overlays + SFX (default on)
# ENABLE_FACELESS_SUBTITLES=false    # Off to disable typewriter keywords on B-roll (default on)
# ENABLE_EXTRA_ONSCREEN_TEXT=false   # Years-only mode — disables stat pills, grain, motion graphics cards
# ENABLE_STRICT_QUALITY_EXPORT=false # Allow export despite low qualityReport score (default on = block)
# MIN_QUALITY_EXPORT_SCORE=45        # Minimum score/100 before upload (default 45)
# ENABLE_YOUTUBE_SOURCING=true       # YouTube CC clips (needs YOUTUBE_API_KEY + RAPIDAPI_KEY)
# ENABLE_EUROPEANA=true              # Off by default — EU Europeana API (needs EUROPEANA_API_KEY)
# EUROPEANA_API_KEY=                 # Only when ENABLE_EUROPEANA=true
# AUTO_ARCHIVE_GEO_RETAG_ON_START=false # Geo bulk-retag optional — matching uses semantic + vision, not geo-tags
# ENABLE_VISION_GEO_GATE=false      # Disable vision-detected geography hard reject (maps/wrong country)
# ENABLE_CLIP_VISION_STOCK=true     # Extra: force stock vision (on by default with ENABLE_VIDRUSH_QUALITY)
# ENABLE_SCENE_CRITICAL_REVIEW=false # Disable post-scene clip replacement pass
# MIN_CLIP_QUALITY_SCORE=8          # Pass threshold 5–10 (default 8)

# ─── Wikimedia + semantic archive matching ─────────────────────────────────────
# WIKIMEDIA_V1_THRESHOLD=65         # Wikimedia still adoption floor (50–95, default 65)
# MIN_WIKI_CLIP_QUALITY_SCORE=6       # Vision floor for Wikimedia clips (4–10, default 6)
# ENABLE_ARCHIVE_EMBEDDING_INDEX=true # Persist text embeddings on upload (semantic search w/o per-beat asset API)
# ENABLE_CLIP_EMBEDDING_INDEX=false   # Local CLIP frame embeddings (@xenova/transformers — heavier, off by default)
# ENABLE_CLIP_GOOD_CACHE=true         # Boost archive assets from prior successful adoptions
# ENABLE_WIKIMEDIA_GEOSEARCH=true     # Wikimedia Commons geosearch by title city GPS
# ENABLE_MONTAGE_CROSSFADE=true       # 0.4s dissolve between montage clips (MONTAGE_XFADE_SEC=0.4)
# ARCHIVE_VISION_TRY_STRICT=8         # Vision-gate up to 8 archive candidates per beat
# ENABLE_POST_RENDER_FFMPEG_DETECT=true # blackdetect + freezedetect + silencedetect on final MP4
# ENABLE_POST_RENDER_SPOT_CHECK=true  # 4-frame luma check on final MP4 before upload (no API cost)
# ENABLE_SEMANTIC_VISUAL_MATCH=true # LLM + embeddings for archive ranking (default on)
# SEMANTIC_MIN_RELEVANCE_SCORE=44   # Archive semantic floor 20–90 (default 44)

# ─── Stock footage (at least ONE required — no grey placeholders without these) ─
PEXELS_API_KEY=          # Primary HD stock video (https://www.pexels.com/api/)
PIXABAY_API_KEY=         # Backup stock (https://pixabay.com/api/docs/)
UNSPLASH_ACCESS_KEY=     # Optional CC photos (https://unsplash.com/developers)

# ─── Voiceover (at least ONE recommended) ─────────────────────────────────────
ELEVENLABS_API_KEY=      # Best quality TTS + custom voices (https://elevenlabs.io)
FISH_AUDIO_API_KEY=      # Fallback TTS if ElevenLabs unset

# ─── Celebrity / person videos (strongly recommended) ─────────────────────────
# YouTube Creative Commons — BOTH search + download required together:
YOUTUBE_API_KEY=         # Google Cloud → YouTube Data API v3 (search CC videos)
RAPIDAPI_KEY=            # RapidAPI: ytstream-download-youtube-videos (download)
# YOUTUBE_CC_DL_SERVICE=  # Optional alt downloader URL instead of RAPIDAPI_KEY

# Person still photos (max 1 Ken Burns still per scene as fallback):
SERPAPI_KEY=             # https://serpapi.com/ → Dashboard → API Key

# Extra celebrity VIDEO without YouTube quota (works for ANY named person):
#   Wikimedia Commons, GDELT TV News (CNN/FOX/MSNBC/BBC via Internet Archive — no key),
#   SepiaSearch/PeerTube, Internet Archive, media.ccc.de, optional sources below:
# FLICKR_API_KEY=          # https://www.flickr.com/services/api/ — CC event/interview video
# EUROPEANA_API_KEY=       # https://www.europeana.eu/en/apis — free key, EU broadcast/documentary video
# VIMEO_ACCESS_TOKEN=      # https://developer.vimeo.com/ — CC-licensed interview/documentary video

# ENABLE_ARCHIVE_AI_TAGS=true     # Auto title/tags from vision on archive upload (needs LLM_API_KEY)
# ENABLE_ARCHIVE_SUBJECT_FILTER=false  # Disable AI subject filter (default on when LLM key set)
# ARCHIVE_SUBJECT_MAX_CLIPS=240  # Skip per-clip subject checks above this count
# ARCHIVE_SCENE_THRESHOLD=0.16   # Visual diff sensitivity (scene filter, 0.08–0.9; lower = more cuts)
# ARCHIVE_SCDET_THRESHOLD=4      # Shot-change detector (scdet, 1–50, lower = more cuts)
# ARCHIVE_MIN_SHOT_CUT_GAP=0.55  # Min seconds between distinct cuts (lower = split more aggressively)
# ARCHIVE_MIN_CLIP_SEC=0.45      # Only merge sub-flash glitches shorter than this (not full shots)
# ARCHIVE_CUT_MERGE_GAP=0.18     # Merge duplicate detections of same cut (seconds)
# ARCHIVE_SPLIT_BUDGET_MS=3600000 # Max processing time for scene split (default 60 min)
# ARCHIVE_MAX_VIDEO_DURATION_SEC=7200  # Max source video length (default 2 hours)
# ARCHIVE_MAX_UPLOAD_MB=2048     # Max upload size for archive (default 2048MB)
# ARCHIVE_SPLIT_CONCURRENCY=4    # Parallel FFmpeg clip extractions

# ─── Production setup (curated library phase) ────────────────────────────────
# Visuals: archive-first — admin media archive, then Wikimedia / Pexels / Pixabay fallbacks.
# ARCHIVE_PEXELS_FALLBACK=false   # Disable stock fallbacks (archive only — not recommended)
# CURATED_ARCHIVE_ONLY=false      # Disable archive-first mode (full external sourcing)
# ENABLE_EXTERNAL_VISUAL_SOURCING=true  # YouTube / Serp / internet stills (off by default)
# Archive stills: smaller photo on blurred background (default on). Set ARCHIVE_BLUR_FILL_STILLS=false for gray mat only.
# ENABLE_FRAMED_ARCHIVE_STILLS=false  # Disable smaller-photo framing entirely
# ELEVENLABS_ONLY=true           # Disable Fish fallback (ElevenLabs only)
# Default: ElevenLabs first; Fish Audio when quota/auth fails (if FISH_AUDIO_API_KEY set)
# FREE_TTS=gtts                  # Testing: skip ElevenLabs/Fish — use free Google TTS (FREE_TTS_LANG=nl|en)
# SKIP_EFFECTS_STAGE=false       # Use generating_effects status (future editing/effects)

# ─── Visual sourcing (archive-first + licensed fallbacks) ────────────────────
# PEXELS_API_KEY and PIXABAY_API_KEY are used when the archive has no match for a beat.
# ARCHIVE_DEDUP_HAMMING=6        # Visual duplicate sensitivity (0=stricter, 12=looser)

# ─── Optional quality toggles ───────────────────────────────────────────────
# PIPELINE_MIN_PER_VIDEO_MIN=10  # Target generation minutes per 1 min of video (default 10)
# PIPELINE_WALL_CLOCK_GRACE=1.2  # Hard fail at target × grace (default 1.2 → ~12 min per 1 min video)
# PIPELINE_WALL_CLOCK_LIMIT=false # Disable wall-clock caps entirely
# MAX_PIPELINE_WALL_CLOCK_MIN=   # Optional fixed target override instead of video_mins × ratio
# QUALITY_OVER_SPEED=false       # Faster Railway mode (default on for archive docs)
# ENABLE_CHAPTER_CARDS=true     # Yellow Vidrush-style chapter cards (default: off)
# ENABLE_STAT_CALLOUTS=true     # Yellow stat boxes on screen (default: off)

# ─── Optional AI clip providers (off by default on Railway short videos) ─────
# STABILITY_AI_API_KEY=
# REPLICATE_API_KEY=
# RUNWAY_API_KEY=
# Kling AI video (beat fallback after Wikimedia — ~$0.35 per 5s clip via FAL)
# FAL_KEY=                        # Recommended: https://fal.ai (Kling 2.5 Turbo Pro)
# KLING_API_KEY=                  # Or direct Kling API (with KLING_API_SECRET)
# KLING_API_SECRET=
# KLING_MODEL=kling-v2-master     # Direct API model name
# KLING_PROVIDER=fal              # fal | direct (default: FAL if set, else direct)
# ENABLE_KLING_BEAT_FALLBACK=true # Last resort only — after wiki/archive/stock/emergency fail
# KLING_MAX_CLIPS_PER_VIDEO=6     # Cap Kling clips per video (cost control)

# ─── Community (homepage Discord CTA) ─────────────────────────────────────────
# VITE_DISCORD_INVITE_URL=https://discord.gg/your-invite-code

# ─── Custom domain (production) ───────────────────────────────────────────────
# Set after adding fastvid.app in Railway → Settings → Networking → Custom Domain
# APP_URL=https://www.fastvid.tech
# Use www until apex (fastvid.tech) redirects to www in TransIP
# DNS: CNAME @ and www → your-service.up.railway.app (values shown in Railway)
# UPLOADS_DIR=/data/uploads
# RAILWAY_VOLUME_MOUNT_PATH=/data

# ─── Object storage (optional — OFF by default, no extra cost) ────────────────
# Leave unset to keep using local disk / Railway volume (free on Railway + volume).
# When your media archive grows or you split web/worker services, create a free
# Cloudflare R2 bucket (10 GB/month free) and set:
# S3_BUCKET=fastvid-media
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_KEY_PREFIX=production          # optional folder prefix inside the bucket
#
# Migrate existing local files after enabling R2 (run on Railway shell or locally with DATABASE_URL):
#   pnpm migrate:storage -- --dry-run
#   pnpm migrate:storage
#   pnpm migrate:storage -- --only=archive
#   pnpm migrate:storage -- --delete-local   # remove local copies after upload

# Stripe / email (not required for video quality)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# RESEND_API_KEY=
# EMAIL_FROM=Fastvid <noreply@fastvid.tech>
