# Copy to .env and fill in values (see Railway dashboard or GitHub secrets for production values).

NODE_ENV=development
PORT=3000

# Required for auth
JWT_SECRET=change-me-local-dev-secret

# Database (MySQL) — optional locally; required for login/videos persistence
# DATABASE_URL=mysql://user:pass@host:3306/fastvid

# OAuth / Manus (optional locally if using email/password only)
# VITE_APP_ID=
# OAUTH_SERVER_URL=

# Admin bootstrap (creates first admin on startup if none exists)
# ADMIN_EMAIL=you@example.com
# ADMIN_PASSWORD=choose-a-strong-password

# AI / media APIs (optional — features disable when unset)
# BUILT_IN_FORGE_API_KEY=
# LLM_API_KEY=
# FISH_AUDIO_API_KEY=
# STABILITY_AI_API_KEY=
# PEXELS_API_KEY=
# ELEVENLABS_API_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# RESEND_API_KEY=
# YouTube CC (both required together for celebrity/person video clips):
# RAPIDAPI_KEY=              # Downloads CC videos (RapidAPI: ytstream-download-youtube-videos)
# YOUTUBE_API_KEY=           # Searches Creative Commons videos (Google Cloud YouTube Data API v3)
# Celebrity / person photos (Google Images via SerpAPI — max 1 still per scene as fallback):
# 1. https://serpapi.com/ → sign up → Dashboard → API Key
# 2. Railway: Variables → New Variable → Name: SERPAPI_KEY  Value: <your key>
# 3. Redeploy, then check: GET /api/health → "SERPAPI_KEY": true
# SERPAPI_KEY=
