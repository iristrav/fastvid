# Copy to .env and fill in values (see Railway dashboard or GitHub secrets for production values).

NODE_ENV=development
PORT=3000

# Required for auth
JWT_SECRET=change-me-local-dev-secret

# Database (MySQL) — optional locally; required for login/videos persistence
# DATABASE_URL=mysql://user:pass@host:3306/fastvid

# OAuth / Manus (optional locally if using email/password only)
# VITE_APP_ID=
# OAUTH_SERVER_URL=

# Admin bootstrap (creates first admin on startup if none exists)
# ADMIN_EMAIL=you@example.com
# ADMIN_PASSWORD=choose-a-strong-password

# AI / media APIs (optional — features disable when unset)
# BUILT_IN_FORGE_API_KEY=
# LLM_API_KEY=
# FISH_AUDIO_API_KEY=
# STABILITY_AI_API_KEY=
# PEXELS_API_KEY=
# ELEVENLABS_API_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# RESEND_API_KEY=
# RAPIDAPI_KEY=              # YouTube CC clip downloads (ytstream on RapidAPI)
# YOUTUBE_API_KEY=           # YouTube Data API v3 — CC video search (Google Cloud)
